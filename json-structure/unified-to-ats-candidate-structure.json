{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AtsCandidate Structure",
  "description": "JSON Structure for AtsCandidate from Unified.to API",
  "structure": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "created_at": {
        "type": "string"
      },
      "updated_at": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "first_name": {
        "type": "string"
      },
      "last_name": {
        "type": "string"
      },
      "emails": {
        "$ref": "property_AtsCandidate_emails"
      },
      "title": {
        "type": "string"
      },
      "telephones": {
        "$ref": "property_AtsCandidate_telephones"
      },
      "company_name": {
        "type": "string"
      },
      "image_url": {
        "type": "string"
      },
      "tags": {
        "$ref": "property_AtsCandidate_tags"
      },
      "address": {
        "$ref": "property_AtsCandidate_address"
      },
      "external_identifier": {
        "type": "string"
      },
      "link_urls": {
        "$ref": "property_AtsCandidate_link_urls"
      },
      "origin": {
        "type": "string",
        "enum": [
          "AGENCY",
          "APPLIED",
          "INTERNAL",
          "REFERRED",
          "SOURCED",
          "UNIVERSITY"
        ]
      },
      "company_id": {
        "type": "string"
      },
      "sources": {
        "$ref": "property_AtsCandidate_sources"
      },
      "date_of_birth": {
        "type": "string"
      },
      "user_id": {
        "type": "string"
      }
    }
  }
}