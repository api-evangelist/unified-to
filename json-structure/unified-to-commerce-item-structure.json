{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommerceItem Structure",
  "description": "JSON Structure for CommerceItem from Unified.to API",
  "structure": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "created_at": {
        "type": "string"
      },
      "updated_at": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "public_name": {
        "type": "string"
      },
      "slug": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "global_code": {
        "type": "string"
      },
      "public_description": {
        "type": "string"
      },
      "is_active": {
        "type": "boolean"
      },
      "is_taxable": {
        "type": "boolean"
      },
      "vendor_name": {
        "type": "string"
      },
      "type": {
        "type": "string"
      },
      "is_visible": {
        "type": "boolean"
      },
      "is_featured": {
        "type": "boolean"
      },
      "weight": {
        "type": "number"
      },
      "weight_unit": {
        "type": "string",
        "enum": [
          "g",
          "kg",
          "oz",
          "lb"
        ]
      },
      "requires_shipping": {
        "type": "boolean"
      },
      "prices": {
        "$ref": "property_CommerceItem_prices"
      },
      "inventory_id": {
        "type": "string"
      }
    }
  }
}