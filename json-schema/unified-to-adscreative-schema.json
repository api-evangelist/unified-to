      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "cta": {
      "type": "string"
    },
    "external_ad_reference": {
      "type": "string"
    },
    "external_creative_reference": {
      "type": "string"
    },
    "external_placement_reference": {
      "type": "string"
    },
    "group_id": {
