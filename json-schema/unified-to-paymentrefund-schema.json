{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/PaymentRefund",
  "title": "PaymentRefund",
  "properties": {
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "payment_id": {
      "type": "string"
    },
    "raw": {
      "additionalProperties": true,
      "type": "object"
    },
    "reference": {
      "type": "string"
    },
    "status": {
      "enum": [
        "SUCCEEDED",
        "PENDING",
        "FAILED",
        "CANCELED"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "total_amount": {
      "type": "number"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "total_amount",
    "payment_id"
  ],
  "type": "object"
}