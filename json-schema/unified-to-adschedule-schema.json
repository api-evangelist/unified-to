{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AdSchedule",
  "title": "AdSchedule",
  "properties": {
    "bid_modifier": {
      "type": "number"
    },
    "day_of_week": {
      "enum": [
        "MONDAY",
        "TUESDAY",
        "WEDNESDAY",
        "THURSDAY",
        "FRIDAY",
        "SATURDAY",
        "SUNDAY"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "end_hour": {
      "type": "number"
    },
    "end_minute": {
      "type": "number"
    },
    "start_hour": {
      "type": "number"
    },
    "start_minute": {
      "type": "number"
    }
  },
  "required": [
    "day_of_week",
    "start_hour",
    "end_hour"
  ],
  "type": "object"
}