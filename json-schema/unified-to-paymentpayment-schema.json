{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/PaymentPayment",
  "title": "PaymentPayment",
  "properties": {
    "account_id": {
      "type": "string"
    },
    "bill_id": {
      "type": "string"
    },
    "contact_id": {
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "currency": {
      "default": "USD",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "invoice_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "payment_method": {
      "type": "string"
    },
    "raw": {
      "additionalProperties": true,
      "type": "object"
    },
    "reference": {
      "type": "string"
    },
    "total_amount": {
      "type": "number"
    },
    "type": {
      "enum": [
        "INVOICE",
        "BILL"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    }
  },
  "type": "object"
}