    "rejected_reason": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "enum": [
        "NEW",
        "REVIEWING",
        "SCREENING",
        "SUBMITTED",
        "FIRST_INTERVIEW",
        "SECOND_INTERVIEW",
        "THIRD_INTERVIEW",
        "BACKGROUND_CHECK",
        "OFFERED",
        "ACCEPTED",
        "HIRED",
        "REJECTED",
        "DECLINED",
        "WITHDRAWN"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    },
    "user_id": {
      "type": "string"
    }
  },
  "type": "object"
}