{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CommerceReservation",
  "title": "CommerceReservation",
  "properties": {
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "end_at": {
      "format": "date-time",
      "type": "string"
    },
    "guest_email": {
      "type": "string"
    },
    "guest_name": {
      "type": "string"
    },
    "guest_phone": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "item_name": {
      "type": "string"
    },
    "location_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "raw": {
      "additionalProperties": true,
      "type": "object"
    },
    "size": {
      "type": "number"
    },
    "staff_name": {
      "type": "string"
    },
    "staff_user_id": {
      "type": "string"
    },
    "start_at": {
      "format": "date-time",
      "type": "string"
    },
    "status": {
      "enum": [
        "PENDING",
        "CONFIRMED",
        "CANCELLED",
        "NO_SHOW",
        "COMPLETED"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    },
    "url": {
      "type": "string"
    }
  },
  "type": "object"
}