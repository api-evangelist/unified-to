{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/property_CrmEvent_task",
  "title": "property_CrmEvent_task",
  "description": "The task object, when type = task",
  "properties": {
    "description": {
      "type": "string"
    },
    "due_at": {
      "format": "date-time",
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "priority": {
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "status": {
      "enum": [
        "COMPLETED",
        "NOT_STARTED",
        "WORK_IN_PROGRESS",
        "DEFERRED"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    }
  },
  "type": "object"
}