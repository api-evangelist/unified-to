{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AtsDocument",
  "title": "AtsDocument",
  "properties": {
    "application_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "document_data": {
      "type": "string"
    },
    "document_url": {
      "type": "string"
    },
    "filename": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "raw": {
      "additionalProperties": true,
      "type": "object"
    },
    "type": {
      "enum": [
        "RESUME",
        "COVER_LETTER",
        "OFFER_PACKET",
        "OFFER_LETTER",
        "TAKE_HOME_TEST",
        "OTHER"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    },
    "user_id": {
      "type": "string"
    }
  },
  "type": "object"
}