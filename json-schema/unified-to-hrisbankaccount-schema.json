{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/HrisBankaccount",
  "title": "HrisBankaccount",
  "properties": {
    "account_number": {
      "type": "string"
    },
    "account_number_last4": {
      "type": "string"
    },
    "account_type": {
      "enum": [
        "CHECKING",
        "SAVINGS"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "bank_name": {
      "type": "string"
    },
    "company_id": {
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "is_primary": {
      "type": "boolean"
    },
    "name": {
      "type": "string"
    },
    "raw": {
      "additionalProperties": true,
      "type": "object"
    },
    "routing_number": {
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    },
    "user_id": {
      "type": "string"
    }
  },
  "type": "object"
}