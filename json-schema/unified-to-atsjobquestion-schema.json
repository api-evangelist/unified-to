    },
    "type": {
      "enum": [
        "TEXT",
        "NUMBER",
        "DATE",
        "BOOLEAN",
        "MULTIPLE_CHOICE",
        "FILE",
        "TEXTAREA",
        "MULTIPLE_SELECT",
        "UNIVERSITY",
        "YES_NO",
        "CURRENCY",
        "URL"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
