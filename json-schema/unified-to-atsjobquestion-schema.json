{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AtsJobQuestion",
  "title": "AtsJobQuestion",
  "properties": {
    "description": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "options": {
      "$ref": "#/components/schemas/property_AtsJobQuestion_options"
    },
    "prompt": {
      "type": "string"
    },
    "question": {
      "type": "string"
    },
    "required": {
