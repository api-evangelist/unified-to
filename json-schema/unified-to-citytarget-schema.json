{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CityTarget",
  "title": "CityTarget",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "radius": {
      "type": "number"
    },
    "radius_unit": {
      "enum": [
        "MILES",
        "KILOMETERS"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    }
  },
  "required": [
    "id"
  ],
  "type": "object"
}