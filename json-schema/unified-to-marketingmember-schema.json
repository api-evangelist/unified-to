    },
    "first_name": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "list_ids": {
      "$ref": "#/components/schemas/property_MarketingMember_list_ids"
    },
