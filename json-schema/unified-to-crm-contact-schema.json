{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/unified-to/refs/heads/main/json-schema/unified-to-crm-contact-schema.json",
  "title": "CrmContact",
  "description": "A contact represents a person that optionally is associated with a deal and/or a company",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "name": {
      "type": "string"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "emails": {
      "$ref": "#/components/schemas/property_CrmContact_emails"
    },
    "telephones": {
      "$ref": "#/components/schemas/property_CrmContact_telephones"
    },
    "deal_ids": {
      "$ref": "#/components/schemas/property_CrmContact_deal_ids"
    },
    "company_ids": {
      "$ref": "#/components/schemas/property_CrmContact_company_ids"
    },
    "address": {
      "$ref": "#/components/schemas/property_CrmContact_address"
    },
    "user_id": {
      "type": "string"
    },
    "link_urls": {
      "$ref": "#/components/schemas/property_CrmContact_link_urls"
    },
    "metadata": {
      "$ref": "#/components/schemas/property_CrmContact_metadata"
    },
    "department": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "raw": {
      "type": "object",
      "additionalProperties": true
    }
  }
}