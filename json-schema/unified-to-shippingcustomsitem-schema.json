{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ShippingCustomsItem",
  "title": "ShippingCustomsItem",
  "properties": {
    "amount": {
      "type": "number"
    },
    "country_of_origin": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "harmonized_tariff_code": {
      "type": "string"
    },
    "quantity": {
      "type": "number"
    },
    "sku": {
      "type": "string"
    },
    "weight": {
      "type": "number"
    },
    "weight_unit": {
      "enum": [
        "g",
        "kg",
        "oz",
        "lb"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    }
  },
  "type": "object"
}