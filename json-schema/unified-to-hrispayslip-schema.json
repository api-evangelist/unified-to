    },
    "details": {
      "$ref": "#/components/schemas/property_HrisPayslip_details"
    },
    "end_at": {
      "format": "date-time",
      "type": "string"
    },
    "gross_amount": {
      "type": "number"
    },
    "id": {
      "type": "string"
    },
    "net_amount": {
      "type": "number"
    },
    "paid_at": {
      "format": "date-time",
      "type": "string"
    },
    "payment_type": {
