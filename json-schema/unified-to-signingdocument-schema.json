{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SigningDocument",
  "title": "SigningDocument",
  "properties": {
    "completed_at": {
      "format": "date-time",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "creator_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "download_url": {
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "raw": {
      "additionalProperties": true,
      "type": "object"
    },
    "sent_at": {
      "format": "date-time",
      "type": "string"
    },
    "status": {
      "enum": [
        "DRAFT",
        "SENT",
        "DELIVERED",
        "IN_PROGRESS",
        "COMPLETED",
        "DECLINED",
        "VOIDED",
        "EXPIRED"
      ],
      "type": "string",
      "x-speakeasy-unknown-values": "allow"
    },
    "template_id": {
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    }
  },
  "type": "object"
}